generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                 @id @default(cuid())
  email           String                 @unique
  passwordHash    String
  nameAr          String
  nameEn          String
  role            Role                   @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  profileImage    String?
  chatSessions    ChatSession[]
  favorites       ScriptFavorite[]
  aiMemories      UserAiMemory[]
  quickScripts    UserQuickScript[]
  tokens          VerificationToken[]
}

model VerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Script {
  id        String           @id @default(cuid())
  key       String           @unique
  title     String
  category  String
  country   Country          @default(ALL)
  language  String           @default("BOTH")
  body      String
  source    String           @default("manual")
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sortOrder Int              @default(0)
  favorites ScriptFavorite[]

  @@index([category])
  @@index([country])
  @@index([language])
  @@index([active])
  @@index([sortOrder])
}

model ScriptFavorite {
  id        String   @id @default(cuid())
  userId    String
  scriptId  String
  createdAt DateTime @default(now())
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scriptId])
  @@index([userId])
  @@index([scriptId])
}

model ChatSession {
  id            String        @id @default(cuid())
  userId        String
  title         String        @default("New chat")
  country       Country       @default(ALL)
  language      String        @default("BOTH")
  memorySummary String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([country])
  @@index([language])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  userId    String
  role      String
  content   String
  imageData String?
  imageName String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([userId])
}

model UserAiMemory {
  id        String   @id @default(cuid())
  userId    String
  country   Country  @default(ALL)
  language  String   @default("BOTH")
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, country, language])
  @@index([userId])
  @@index([country])
  @@index([language])
}

model AiKnowledgeItem {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  country   Country  @default(ALL)
  language  String   @default("BOTH")
  kind      String   @default("Internal Note")
  sourceUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country, active])
  @@index([language, active])
  @@index([kind])
  @@map("AiKnowledgeItem")
}

model AiGlobalMemory {
  id        String   @id @default(cuid())
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  key       String   @unique @default("global")
  value     String   @default("")

  @@map("AiGlobalMemory")
}

model UserQuickScript {
  id        String   @id @default(cuid())
  userId    String
  title     String
  country   Country  @default(ALL)
  language  String   @default("AR")
  body      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([country])
  @@index([language])
  @@index([active])
  @@index([sortOrder])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Country {
  ALL
  KSA
  UAE
}

enum ScriptLanguage {
  AR
  EN
}
