generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Country {
  ALL
  KSA
  UAE
}

enum ScriptLanguage {
  AR
  EN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  nameAr          String
  nameEn          String
  profileImage    String?
  role            Role      @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tokens          VerificationToken[]
  favorites       ScriptFavorite[]

  // Old v5 chat tables kept to prevent data loss.
  chatSessions    ChatSession[]
  aiMemories      UserAiMemory[]

  // New professional AI trainer/chat tables.
  aiChatSessions  AiChatSession[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Script {
  id        String         @id @default(cuid())
  key       String         @unique
  title     String
  category  String
  country   Country        @default(ALL)
  language  ScriptLanguage @default(AR)
  body      String
  source    String         @default("manual")
  active    Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  favorites ScriptFavorite[]
}

model ScriptFavorite {
  id        String   @id @default(cuid())
  userId    String
  scriptId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([userId, scriptId])
  @@index([userId])
  @@index([scriptId])
}

// Legacy v5 per-user chat history. Kept so Prisma will not drop existing data.
model ChatSession {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String         @default("New chat")
  country       Country        @default(KSA)
  language      ScriptLanguage @default(AR)
  memorySummary String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      ChatMessage[]

  @@index([userId, updatedAt])
}

// Legacy v5 messages. Kept so Prisma will not drop existing data.
model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  role      String
  content   String
  imageData String?
  imageName String?
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@index([userId])
}

// Legacy v5 per-user AI memory. Kept so Prisma will not drop existing data.
model UserAiMemory {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  country   Country        @default(KSA)
  language  ScriptLanguage @default(AR)
  summary   String         @default("")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, country, language])
  @@index([userId])
}

// New professional AI chatbot sessions.
model AiChatSession {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String          @default("New chat")
  messages  AiChatMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId, updatedAt])
}

model AiChatMessage {
  id           String        @id @default(cuid())
  sessionId    String
  session      AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String
  content      String        @db.Text
  imageDataUrl String?       @db.Text
  createdAt    DateTime      @default(now())

  @@index([sessionId, createdAt])
}

// Shared anonymized memory used by the AI. Does not expose one user's chats to another.
model AiGlobalMemory {
  id        String   @id @default("global")
  summary   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-managed knowledge base for PureGym policies, sources, links, and internal notes.
model AiKnowledgeItem {
  id          String         @id @default(cuid())
  title       String
  body        String         @db.Text
  country     Country        @default(ALL)
  language    ScriptLanguage @default(EN)
  sourceType  String         @default("manual")
  sourceUrl   String?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([country, language, active])
}
