# ============================================================
# PureGym Support Hub - Environment Variables
# Copy to .env locally and fill real values.
# On Vercel: Project > Settings > Environment Variables.
# ============================================================

NODE_ENV=development
APP_NAME="PureGym Support Hub"
APP_URL=http://localhost:3000
PORT=3000

# Neon PostgreSQL connection string (use the pooled URL on Vercel).
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Generate strong values: openssl rand -base64 32
AUTH_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Initial admin created by: npm run db:seed
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME_AR=
ADMIN_NAME_EN=

# Gmail SMTP verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="PureGym Support Hub"
SMTP_FROM_EMAIL=
VERIFY_EMAIL_TOKEN_EXPIRES_MINUTES=1440

# OpenAI chatbot + spellcheck button
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=1200

# Google Sheet reference / future import (optional)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_URL=

# PureGym official links - update anytime from Admin > Links or seed data
KSA_BASE_URL=https://ksa.puregymarabia.com
UAE_BASE_URL=https://uae.puregymarabia.com

# Security
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ALLOWED_ORIGINS=http://localhost:3000
