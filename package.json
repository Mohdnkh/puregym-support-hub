{
  "name": "puregym-support-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "smoke": "tsx scripts/smoke-tests.ts",
    "docs:generate": "python scripts/generate-project-artifacts.py",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:export": "tsx scripts/export-seed.ts",
    "db:audit-legacy-quick-scripts": "tsx scripts/audit-legacy-quick-scripts.ts",
    "db:cleanup-legacy-quick-scripts": "tsx scripts/audit-legacy-quick-scripts.ts --cleanup",
    "content:sync-standard": "tsx scripts/import-quick-scripts.ts && tsx scripts/sync-official-links.ts && tsx scripts/run-offer-sync.ts",
    "content:import-sheet-knowledge": "tsx scripts/import-sheet-knowledge.ts",
    "railway-build": "prisma generate && next build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/functions": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.18",
    "nodemailer": "^6.9.16",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
